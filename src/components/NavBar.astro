---
import ThemeToggle from "./ThemeToggle.astro";
---

<script>
  const navMenu = document.getElementById("navMenu") as HTMLDivElement;
  const burgerButton = document.getElementById("burgerButton") as HTMLButtonElement;
  const navbarLinks = document.getElementsByClassName("navbar-link");

  burgerButton.addEventListener("click", () => {
    navMenu.classList.toggle("active");
    burgerButton.classList.toggle("active");
    if (navMenu.classList.contains("active")) document.body.style.overflow = "hidden";
    else document.body.style.overflow = "visible";
  });

  for (const navbarLink of navbarLinks) {
    navbarLink.addEventListener("click", () => {
      navMenu.classList.remove("active");
      burgerButton.classList.remove("active");
      document.body.style.overflow = "visible";
      return true;
    });
  }
</script>

<style>
  #burgerButton.active span:nth-child(1) {
    @apply translate-y-2.5 rotate-45;
  }

  #burgerButton.active span:nth-child(3) {
    @apply -translate-y-2.5 -rotate-45;
  }

  #burgerButton.active span:nth-child(2) {
    @apply opacity-0;
  }

  #navMenu.active {
    @apply absolute inset-0 block h-screen bg-beige px-2 pt-28 text-center lg:static lg:pt-0;
  }
</style>

<header class="relative z-10">
  <nav class="bg-beige shadow-navbar">
    <div class="wrapper flex items-center justify-between py-4">
      <div class="flex items-center gap-24">
        <a href="/" class="shrink-0">
          <img
            src="/images/logo.png"
            alt="octolib logo"
            width="90"
            height="51"
            class="dark:hidden"
          />
          <img
            src="/images/logo-dark-mode.png"
            alt="octolib logo"
            width="90"
            height="51"
            class="hidden dark:block"
          />
        </a>
        <a
          href="https://github.com/yamanidev/octolib.org/blob/main/CONTRIBUTIONS.md"
          class="hidden rounded-md bg-blue-light px-5 py-1 text-xl font-bold text-beige transition hover:bg-blue-dark dark:bg-blue-dark dark:text-beige dark:hover:bg-[#2B9AAE] dark:hover:text-blue-dark lg:block"
          rel="noreferrer"
          target="_blank">
          Contribute
        </a>
      </div>
      <div class="flex items-center gap-4">
        <div id="navMenu" class="hidden lg:block">
          <ul
            class="flex flex-col gap-9 text-2xl font-bold text-blue-light dark:text-blue-dark lg:w-[29rem] lg:flex-row lg:justify-between lg:gap-0 lg:text-base">
            <li>
              <a
                href="#1CP"
                class="navbar-link transition hover:text-blue-dark dark:hover:text-[#D4A040]">
                1CP
              </a>
            </li>
            <li>
              <a
                href="#2CP"
                class="navbar-link transition hover:text-blue-dark dark:hover:text-[#D4A040]">
                2CP
              </a>
            </li>
            <li>
              <a
                href="#1CS"
                class="navbar-link transition hover:text-blue-dark dark:hover:text-[#D4A040]">
                1CS
              </a>
            </li>
            <li>
              <a
                href="#2CS"
                class="navbar-link transition hover:text-blue-dark dark:hover:text-[#D4A040]">
                2CS
              </a>
            </li>
            <li>
              <a
                href="#3CS"
                class="navbar-link transition hover:text-blue-dark dark:hover:text-[#D4A040]">
                3CS
              </a>
            </li>
          </ul>
          <div
            class="mx-auto mt-12 h-0.5 max-w-[16.5rem] bg-blue-light dark:bg-blue-dark lg:hidden">
          </div>
          <a
            href="https://github.com/yamanidev/octolib.org/blob/main/CONTRIBUTIONS.md"
            class="mt-10 inline-block rounded-md bg-blue-light px-5 py-1 text-xl font-bold text-beige transition hover:bg-blue-dark dark:bg-blue-dark dark:text-beige dark:hover:bg-[#2B9AAE] dark:hover:text-blue-dark lg:hidden"
            rel="noreferrer"
            target="_blank">
            Contribute
          </a>
        </div>
        <ThemeToggle />
        <button
          id="burgerButton"
          aria-label="toggle navigation menu"
          class="relative z-10 flex flex-col gap-1 lg:hidden">
          <span
            class="inline-block h-1.5 w-12 bg-blue-light transition duration-500 dark:bg-blue-dark">
          </span>
          <span
            class="inline-block h-1.5 w-12 bg-blue-light transition duration-300 dark:bg-blue-dark">
          </span>
          <span
            class="inline-block h-1.5 w-12 bg-blue-light transition duration-500 dark:bg-blue-dark">
          </span>
        </button>
      </div>
    </div>
  </nav>
</header>
